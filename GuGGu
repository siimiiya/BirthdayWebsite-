<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday Guggu!</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #fce4ec 0%, #f8bbd0 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow: hidden;
        }

        .card {
            background: rgba(255, 255, 255, 0.9);
            padding: 3rem;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            text-align: center;
            max-width: 500px;
            z-index: 10;
            border: 2px solid #f06292;
        }

        h1 {
            color: #d81b60;
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        p {
            color: #4a4a4a;
            font-size: 1.2rem;
            line-height: 1.6;
        }

        .heart {
            color: #e91e63;
            font-size: 3rem;
            animation: beat 1s infinite;
        }

        @keyframes beat {
            0% { transform: scale(1); }
            50% { transform: scale(1.2); }
            100% { transform: scale(1); }
        }

        /* Floating Bubbles/Hearts Background */
        .bg-elements {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        .floating {
            position: absolute;
            bottom: -100px;
            background-color: rgba(233, 30, 99, 0.2);
            border-radius: 50%;
            animation: float 10s infinite linear;
        }

        @keyframes float {
            to {
                transform: translateY(-110vh);
            }
        }
    </style>
</head>
<body>

    <div class="bg-elements" id="bg"></div>

    <div class="card">
        <div class="heart">❤️</div>
        <h1>Happy Birthday, Guggu!</h1>
        <p>To my beautiful wife,</p>
        <p>You make every single day brighter just by being in it. I love you more than words can express. May your year be as wonderful and lovely as you are.</p>
        <p><strong>Forever Yours,</strong></p>
    </div>

    <script>
        // Generate floating circles for a festive vibe
        const bg = document.getElementById('bg');
        for (let i = 0; i < 20; i++) {
            const circle = document.createElement('div');
            circle.classList.add('floating');
            const size = Math.random() * 50 + 10 + 'px';
            circle.style.width = size;
            circle.style.height = size;
            circle.style.left = Math.random() * 100 + 'vw';
            circle.style.animationDuration = Math.random() * 5 + 5 + 's';
            circle.style.animationDelay = Math.random() * 5 + 's';
            bg.appendChild(circle);
        }
    </script>
</body>
</html>

